\setbeamertemplate{title page}{
  \null%
  \vspace{0pt plus 1.618fil}%
  \vfil%
  \snt@titlepage@addtoplogo\\%
  \vspace{1ex}%
  \ifx\inserttitle\@empty\else\usebeamertemplate*{title}\fi
  \ifx\insertsubtitle\@empty\else\usebeamertemplate*{subtitle}\fi
  \expandafter\ifblank\expandafter{\beamer@andstripped}{}{%
  \usebeamertemplate*{author}%
  }
  \ifx\insertinstitute\@empty\else\usebeamertemplate*{institute}\fi
  \ifx\insertdate\@empty\else\usebeamertemplate*{date}\fi
  \vspace{0pt plus 1fil}%
  \null
  \begin{tikzpicture}[remember picture,overlay,shift={(current page.south east)}]
    \node[anchor=south east] (snt-ul) {\snt@titlepage@addbottomlogo};
    \node[anchor=south east] at (snt-ul.south west) {%
      \ifx\inserttitlegraphic\@empty\else\usebeamertemplate*{title graphic}\fi
    };
  \end{tikzpicture}
}
\def\maketitle{%
  \ifbeamer@inframe
    \titlepage
  \else
    \begingroup
    \renewcommand\footnoterule{}%
    \ifbool{snt@titlepage@withbackground}{%
      \usebackgroundtemplate{\includegraphics[width=\paperwidth]{assets/backgrounds/background-normal}}%
      \setbeamercolor{normal text}{fg=white}%
    }{}%
    \frame[plain,noframenumbering]{\titlepage}
    \endgroup
  \fi
}
\def\titlepage{%
  % Apply title-page specific footnote settings
  \renewcommand{\@makefntext}[1]{%
    {\par\usebeamercolor[fg]{thanks}\usebeamerfont{thanks}$^{\@thefnmark}$##1\medskip}%
  }
  % Process the title page
  \usebeamertemplate{title page}\@thanks
}
\setbeamertemplate{title graphic}{\inserttitlegraphic}
\setbeamertemplate{title}{
  \raggedright%
  \snt@titleformat{\inserttitle}%
  \par%
}
\setbeamertemplate{subtitle}{
  \vspace*{0.1em}
  \raggedright%
  \snt@subtitleformat{\insertsubtitle}%
  \par%
  \vspace*{0.2em}
}
\setbeamertemplate{title separator}{
  \tikzexternaldisable%
  \begin{tikzpicture}[baseline=(current bounding box.north)]
    \mmzUnmemoizable%
    \fill[fg] (0,0) rectangle (\textwidth, \snt@titleseparator@linewidth);
    \useasboundingbox (0,0) rectangle (\textwidth,-\snt@titleseparator@linewidth);
  \end{tikzpicture}%
  \tikzexternalenable%
  \par%
  \vspace*{0.8em}
}
\setbeamertemplate{author}{
  \vspace*{0.5em}%
  \raggedright%
  \insertauthor%
  \par
}
\setbeamertemplate{institute}{
  \vspace*{1em}%
  \insertinstitute%
  \par
}
\setbeamertemplate{date}{
  \vspace*{0.5em}%
  \insertdate%
  \par
}
\newcommand{\snt@sectionpagemarker}[1]{%
  {\usebeamercolor[fg]{normal text}\color{fg!55!bg}\normalfont\mdseries\normalsize\makebox[0pt][r]{#1\hspace{0.55em}}}%
}
\defbeamertemplate{section page}{simple}{
  \begin{center}
    \usebeamercolor[fg]{section title}
    \usebeamerfont{section title}
    \snt@sectionpagemarker{\S}\snt@sectiontitleformat{\insertsectionhead}\par
  \end{center}
  \vspace{\baselineskip - 1ex + \snt@titleseparator@linewidth}
}
\defbeamertemplate{section page}{progressbar}{
  \centering
  \begin{minipage}{0.7875\linewidth}
    \raggedright
    \usebeamercolor[fg]{section title}
    \usebeamerfont{section title}
    \snt@sectionpagemarker{\S}\snt@sectiontitleformat{\insertsection}\\[-0.5\baselineskip]
    \usebeamertemplate*{progress bar in section page}
  \end{minipage}
  \par
}
\newcommand{\snt@disablesectionpage}{
  \AtBeginSection{
    % intentionally empty
  }
}
\newcommand{\snt@enablesectionpage}{
  \AtBeginSection{
    \ifbeamer@inframe
      \sectionpage
    \else
      \frame[plain,c,noframenumbering]{\sectionpage}
    \fi
  }
}
\setbeamertemplate{subsection page}{%
  \centering
  \begin{minipage}{0.7875\linewidth}
    \raggedright
    \usebeamercolor[fg]{section title}
    \usebeamerfont{section title}
    \ifx\insertsubsectionhead\@empty
      \snt@sectionpagemarker{\S}\snt@sectiontitleformat{\insertsection}
    \else
      %\snt@sectionpagemarker{\S\S}
      \snt@sectiontitleformat{\insertsubsection}
    \fi\\[-0.5\baselineskip]
    \usebeamertemplate*{progress bar in section page}
  \end{minipage}

  \begin{tikzpicture}[remember picture,overlay]
    \node[anchor=north west, xshift=1.6em, yshift=-1.2ex] at (current page.north west) {%
      \usebeamercolor[fg]{normal text}%
      \normalsize~\snt@sectionpagemarker{\S}\insertsection%
    };
  \end{tikzpicture}%
}
\newcommand{\snt@disablesubsectionpage}{
  \AtBeginSubsection{
    % intentionally empty
  }
}
\newcommand{\snt@enablesubsectionpage}{
  \AtBeginSubsection{
    \ifbeamer@inframe
      \subsectionpage
    \else
      \frame[plain,c,noframenumbering]{\subsectionpage}
    \fi
  }
}
\setbeamertemplate{progress bar in section page}{
  \ifnum\insertmainframenumber=0
  \pgfmathsetlength{\snt@progressonsectionpage}{\textwidth}
\else
  \pgfmathsetlength{\snt@progressonsectionpage}{%
    \textwidth * min(1,\insertframenumber/\insertmainframenumber)%
  }%
\fi
  \tikzexternaldisable%
  \begin{tikzpicture}[baseline=(current bounding box.north)]
    \mmzUnmemoizable%
    \fill[bg]
    (0,0)
    rectangle
    (\textwidth, \snt@progressonsectionpage@linewidth);
    \fill[fg]
    (0,0)
    rectangle
    (\snt@progressonsectionpage,
    \snt@progressonsectionpage@linewidth);
    \useasboundingbox (0,0) rectangle (\textwidth,-\snt@progressonsectionpage@linewidth);
  \end{tikzpicture}%
  \tikzexternalenable%
}
