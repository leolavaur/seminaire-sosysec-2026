\define@key{beamerframe}{c}[true]{% centered
  \beamer@frametopskip=0pt plus 1fil\relax%
  \beamer@framebottomskip=0pt plus 1fil\relax%
  \beamer@frametopskipautobreak=0pt plus .4\paperheight\relax%
  \beamer@framebottomskipautobreak=0pt plus .6\paperheight\relax%
  \def\beamer@initfirstlineunskip{}%
}
\providebool{snt@standout}
\define@key{beamerframe}{standout}[true]{%
  \booltrue{snt@standout}
  \begingroup
  \setkeys{beamerframe}{c}
  \ifbool{snt@enableStandoutNumbering}{}{%
    \setkeys{beamerframe}{noframenumbering}}
  \ifbeamercolorempty[bg]{palette primary}{
    \setbeamercolor{background canvas}{
      use=palette primary,
      bg=-palette primary.fg
    }
  }{
    \setbeamercolor{background canvas}{
      use=palette primary,
      bg=palette primary.bg
    }
  }
  \setbeamercolor{local structure}{
    fg=palette primary.fg
  }
  \usebeamercolor[fg]{palette primary}
  \setbeamercolor{page number in head/foot}{
    use=palette primary,
    fg=palette primary.fg
  }
  \ifbool{snt@enableStandoutFooter}{}{\setbeamertemplate{footline}{}}
}
\pretocmd{\beamer@reseteecodes}{%
  \ifbool{snt@standout}{
    \endgroup
    \boolfalse{snt@standout}
  }{}
}{}{}
\AtBeginEnvironment{beamer@frameslide}{
  \ifbool{snt@standout}{
    \centering
    \usebeamerfont{standout}
  }{}
}
