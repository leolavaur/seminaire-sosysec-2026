@article{li_ScallopLanguageNeurosymbolic_2023,
  title        = {Scallop: {{A Language}} for {{Neurosymbolic Programming}}},
  shorttitle   = {Scallop},
  author       = {Li, Ziyang and {https://orcid.org/0000-0003-3925-9549} and {View Profile} and Huang, Jiani and {https://orcid.org/0000-0003-3803-7995} and {View Profile} and Naik, Mayur and {https://orcid.org/0000-0003-1348-8618} and {View Profile}},
