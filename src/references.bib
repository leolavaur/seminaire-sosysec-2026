  shorttitle = {{{BRITE}}},
  booktitle  = {{{MASCOTS}} 2001, {{Proceedings Ninth International Symposium}} on {{Modeling}}, {{Analysis}} and {{Simulation}} of {{Computer}} and {{Telecommunication Systems}}},
  author     = {Medina, A. and Lakhina, A. and Matta, I. and Byers, J.},
  date       = {2001-08},
